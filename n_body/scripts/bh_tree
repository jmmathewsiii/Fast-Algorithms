set size square
set xrange [-4:4]
set yrange [-4:4]
set xlabel 'x'
set ylabel 'y'
unset key
do for [i=0:100] {
    set title sprintf('bh_tree  frame %d', i)
    plot sprintf('../output/bh_tree_%05d_tree.plt', i) with lines lc rgb 'gray60', \
         sprintf('../output/bh_tree_%05d_particles.plt', i) with points pt 7 ps 0.5 lc rgb 'black'
    pause 0.005
}
